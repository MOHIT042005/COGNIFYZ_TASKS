<!DOCTYPE html>
<html lang="en">
<head>
    <title>Form</title>
    <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
     <link rel="stylesheet" href="/style.css">
</head>

<body>
    <!-- NAVBAR-->
     <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <span class="navbar-brand">REGISTRATION APP</span>
        </div>
     </nav>

    <!-- Form -->
     <div class="container mt-5">
        
        <div class="card p-4 shadow form-card">

            <h3 class="text-center mb-4">Register</h3>

            <form name="myform" action="/submit" method="POST" onsubmit="return validateForm()">

                <input class="form control mb-3" type="text" name="username" placeholder="Enter name">
                <input class="form-control mb-3" type="email" name="useremail" placeholder="Enter your email">
                <input class="form-control mb-3" type="number" name="phonenumber" placeholder="Enter your phonenumber">
                <button class="btn btn-primary w-100">Submit</button>
            </form>

        </div>

     </div>

     <!--Footer-->
     <footer class="bg-dark text-white text-center mt-5 p-3">
        @ 2026 Form APP
     </footer>
<script>

        function validateForm() {
            let name = document.forms["myform"]["username"].value;
            let email = document.forms["myform"]["useremail"].value;
            let phone = document.forms["myform"]["phone"].value;

            if(name === "" || email === "" || phone === "") {
                alert("All fields are required!");
                return false;
            }
            if(name === "") {
                alert("Username cannot be empty");
                return false;
            }
            if(!email.includes("@")) {
                alert("Invalid email!");
                return false;
            }
            if(phone.length !== 10) {
                alert("Phone must be 10 digits!");
                return false;
            }
            

            return true;
        }
    </script>
</body>
</html>